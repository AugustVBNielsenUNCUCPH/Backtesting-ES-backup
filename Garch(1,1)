sigma_low  <- sigma(garch_low)

# Høj volatilitet
omega_h <- coef_high["omega"]
alpha_h <- coef_high["alpha1"]
beta_h  <- coef_high["beta1"]
nu_h <- coef_high["shape"]

E_sigma2_high <- omega_h / (1 - alpha_h - beta_h)

# Lav volatilitet
omega_l <- coef_low["omega"]
