  # H0 model anvendes til test
  sigma_H0 <- simulate_sigma_from_X(sim_H1_low$X, omega_l, alpha_l, beta_l)
  
  VaR_H1 <- VaR_GARCH_stdt(sigma_H0, alpha_VaRtest, nu_l)
  VaR_H1_0.025 <- VaR_GARCH_stdt(sigma_H0, alpha, nu_l)
