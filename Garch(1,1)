## CC test
CC_test_GARCH <- function(X, VaR, ES, alpha){

  M <- nrow(X)
  T <- ncol(X)

  T_CC <- matrix(0, M, 2)

  for(i in 1:M){

    xt <- X[i,]
    r1 <- VaR[i,]
    r2 <- ES[i,]

    V <- cbind(
      alpha - (xt + r1 < 0)*1,
      r1 - r2 - (1/alpha)*(xt + r1 < 0)*(r1 + xt)
    )

    Omega <- crossprod(V)/T
    # Teststørrelse
    T_CC[i,] <- sqrt(T)*diag(Omega)^(-1/2)*colMeans(V)}
  T_CC}

## CC styrke
CC_power <- function(T_CC_null, T_CC){

  pi1 <- ecdf(T_CC_null[,1])
  pi2 <- ecdf(T_CC_null[,2])

  eta <- 2 * pmin(pi1(T_CC[,1]), pi2(T_CC[,2]))
  eta <- pmin(eta, 1)

  mean(eta < 0.0412)}

## Exceedance Residuals test
ER_test_GARCH <- function(X, ES, VaR, sigma){

  I <- (X < -VaR)

  r <- ((X + ES) * I)/sigma

  rbar <- rowSums(r) / rowSums(I)

  rbar[!is.finite(rbar)] <- NA

  rbar}

## ER styrke
ER_power <- function(ER, q){
  1 - mean(ER >= q, na.rm = TRUE)}

