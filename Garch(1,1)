low_vol  <- returns["2013-01-01/2015-12-31"]

# GARCH(1,1) model
spec <- ugarchspec(
  variance.model=list(
    model="sGARCH",
    garchOrder=c(1,1)),
  mean.model=list(
    armaOrder=c(0,0),
    include.mean=FALSE),
  distribution.model="std")

# Estimering af parametre
garch_high <- ugarchfit(
  spec=spec,
  data=as.numeric(high_vol))

