Z2_H0_high <- Z2_test_GARCH(sim_H0_high$X, VaR_H0_high, ES_H0_high, alpha)

## Z3
Z3_test_GARCH <- function(X, sigma, alpha, nu){
  
  T <- ncol(X)
  
  z <- X / sigma
  U <- pt(z * sqrt(nu/(nu-2)), df = nu)
  U <- pmin(pmax(U, 1e-10), 1-1e-10)
  U_sorted <- t(apply(U, 1, sort, method = "quick"))
  q <- qt(U_sorted, df = nu)
  
  k <- floor(T * alpha)
  ES_emp <- -rowMeans(q[, 1:k, drop = FALSE])
  
  q_alpha <- qt(alpha, nu)
  ES_theo <- (dt(q_alpha, nu)/alpha) * (nu + q_alpha^2)/(nu - 1)
  
  Z3 <- 1 - (ES_emp / ES_theo)}


### fordeling af Z3 under H0
Z3_H0_low  <- Z3_test_GARCH(sim_H0_low$X,  sim_H0_low$sigma,  alpha, nu_l)
Z3_H0_high <- Z3_test_GARCH(sim_H0_high$X, sim_H0_high$sigma, alpha, nu_h)

