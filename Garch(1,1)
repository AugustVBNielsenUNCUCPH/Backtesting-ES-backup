# Teststørrelser
## VaR 
VaR_test_GARCH <- function(X, VaR){
  (X + VaR < 0) * 1
}

## VaR, antal overskridelser
VaR_stat_GARCH <- function(X, VaR){
  rowSums(X + VaR < 0)
}

### hit rates
hit_rate_low  <- rowMeans(VaR_test_GARCH(sim_H0_low$X, VaR_H0_low))
hit_rate_high <- rowMeans(VaR_test_GARCH(sim_H0_high$X, VaR_H0_high))

## Z2 
Z2_test_GARCH <- function(X, VaR, ES, alpha){
  
  I <- (X + VaR < 0)
  
  rowMeans((X * I) / (alpha * ES)) + 1
}
### fordeling af Z2 under H0
Z2_H0_low  <- Z2_test_GARCH(sim_H0_low$X,  VaR_H0_low,  ES_H0_low,  alpha)
Z2_H0_high <- Z2_test_GARCH(sim_H0_high$X, VaR_H0_high, ES_H0_high, alpha)

## Z3
Z3_test_GARCH <- function(X, sigma, alpha, nu){
  
  M <- nrow(X)
  T <- ncol(X)
  
  Z <- numeric(M)
  
  for(i in 1:M){
    
    # 1. standardiserede residualer
    z <- X[i,] / sigma[i,]
    
    # 2. rang (U_t)
    U <- pt(z * sqrt(nu/(nu-2)), df = nu)
    
    # 3. sorter U (empirisk rang)
    U_sorted <- sort(U)
    
    # 4. inverse PIT (teoretisk model)
    q <- qt(U_sorted, df = nu)
    
    # 5. ES baseret på orden-statistik
    k <- floor(T * alpha)
    
    ES_emp <- -mean(q[1:k])
    
    # 6. forventet ES (konstant for t-fordeling)
    q_alpha <- qt(alpha, nu)
    
    ES_theo <- (dt(q_alpha, nu)/alpha) *
               (nu + q_alpha^2)/(nu - 1)
    
    # 7. Z3
    Z[i] <- - (ES_emp / ES_theo) + 1
  }
  
  Z
}

### fordeling af Z3 under H0
Z3_H0_low  <- Z3_test_GARCH(sim_H0_low$X,  sim_H0_low$sigma,  alpha, nu_l)
Z3_H0_high <- Z3_test_GARCH(sim_H0_high$X, sim_H0_high$sigma, alpha, nu_h)

# Kritiske værdier
q_Z2_low  <- quantile(Z2_H0_low, 0.0412)
q_Z3_low  <- quantile(Z3_H0_low, 0.0412)

q_Z2_high <- quantile(Z2_H0_high, 0.0412)
q_Z3_high <- quantile(Z3_H0_high, 0.0412)

# VaR kritisk værdi, binomial test
q_VaR <- qbinom(1 - 0.05, size = T, prob = alpha_VaRtest)


# Omega faktor
omega_seq <- seq(0.2, 2.6, by = 0.2)

omega_alt_low_vec  <- omega_l * omega_seq
omega_alt_high_vec <- omega_h * omega_seq


# Styrke, lav volatilitet
power_VaR_low <- numeric(length(omega_seq))
power_Z2_low  <- numeric(length(omega_seq))
power_Z3_low  <- numeric(length(omega_seq))

for(i in 1:length(omega_seq)){
  
  omega_alt <- omega_alt_low_vec[i]
  
  # H1 (ændret omega)
  sim_H1_low <- simulate_garch(T, omega_alt, alpha_l, beta_l, nu_l, burn_in, M)
  
  # H0 model anvendes til test (KRITISK!)
  sigma_H0 <- simulate_sigma_from_X(sim_H1_low$X, omega_l, alpha_l, beta_l)
  
  VaR_H1 <- VaR_GARCH_stdt(sigma_H0, alpha_VaRtest, nu_l)
  VaR_H1_0.025 <- VaR_GARCH_stdt(sigma_H0, alpha, nu_l)
  ES_H1  <- ES_GARCH_stdt(sigma_H0, alpha, nu_l)
  
  Z2_H1 <- Z2_test_GARCH(sim_H1_low$X, VaR_H1_0.025, ES_H1, alpha)
  Z3_H1 <- Z3_test_GARCH(sim_H1_low$X, sigma_H0, alpha, nu_l)
  VaR_hits <- VaR_stat_GARCH(sim_H1_low$X, VaR_H1)
  
  power_VaR_low[i] <- mean(VaR_hits > q_VaR)
  power_Z2_low[i] <- mean(Z2_H1 < q_Z2_low)
  power_Z3_low[i] <- mean(Z3_H1 < q_Z3_low)
}


# Styrke, høj volatilitet
