library(quantmod)
library(rugarch)
library(cvar)

# Data hentes fra S&P500
getSymbols("^GSPC", from="2000-01-01")

prices <- Ad(GSPC)

returns <- 100 * diff(log(prices), lag = 1)
returns <- na.omit(returns)

# Perioder med hhv. høj og lav volatilitet
high_vol <- returns["2020-01-01/2023-12-29"]
low_vol  <- returns["2023-01-03/2024-12-31"]

# GARCH(1,1) model
spec <- ugarchspec(
  variance.model=list(
    model="sGARCH",
    garchOrder=c(1,1)),
  mean.model=list(
    armaOrder=c(0,0),
    include.mean=FALSE),
  distribution.model="std")

# Estimering af parametre
garch_high <- ugarchfit(
  spec=spec,
  data=as.numeric(high_vol))

garch_low <- ugarchfit(
  spec=spec,
  data=as.numeric(low_vol))

coef_high <- coef(garch_high)
coef_low <- coef(garch_low)

param_table <- data.frame(
  Parameter=names(coef_high),
  HighVol=coef_high,
  LowVol=coef_low)

print(param_table)

sigma_high <- sigma(garch_high)
sigma_low  <- sigma(garch_low)

# Høj volatilitet
omega_h <- coef_high["omega"]
alpha_h <- coef_high["alpha1"]
beta_h  <- coef_high["beta1"]
nu_h <- coef_high["shape"]

E_sigma2_high <- omega_h / (1 - alpha_h - beta_h)

# Lav volatilitet
omega_l <- coef_low["omega"]
alpha_l <- coef_low["alpha1"]
beta_l  <- coef_low["beta1"]
nu_l <- coef_low["shape"]

E_sigma2_low <- omega_l / (1 - alpha_l - beta_l)

# Ubetinget varians og stationaritetsbetingelse
E_sigma2_high
E_sigma2_low

alpha_beta_høj <- alpha_h + beta_h
alpha_beta_lav <- alpha_l + beta_l

if(alpha_beta_høj < 1) print("Høj volatilitet: Stationær")
if(alpha_beta_lav < 1) print("Lav volatilitet: Stationær")


# GARCH(1,1) simulationsfunktion
simulate_garch <- function(T, omega, alpha, beta, nu, burn_in, M) {
  
  total <- T + burn_in
  tau <- sqrt((nu - 2) / nu)
  
  X <- matrix(0, M, total)
  sigma2 <- matrix(0, M, total)
  
  sigma2[,1] <- omega / (1 - alpha - beta)
  
  for (t in 2:total) {
    
    z <- rt(M, df = nu) * tau
    
    X[,t-1] <- sqrt(sigma2[,t-1]) * z
    
    sigma2[,t] <- omega +
                  alpha * X[,t-1]^2 +
                  beta  * sigma2[,t-1]
  }
  
  X <- X[, (burn_in+1):total]
  sigma <- sqrt(sigma2[, (burn_in+1):total])
  
  list(X = X, sigma = sigma)
}

# VaR OG ES
VaR_GARCH_stdt <- function(sigma, alpha, nu) {
  -sigma * qt(alpha, nu) * sqrt((nu - 2)/nu)
}

ES_GARCH_stdt <- function(sigma, alpha, nu) {
  q <- qt(alpha, nu)
  sigma * sqrt((nu - 2)/nu) *
    (dt(q, nu)/alpha) *
    (nu + q^2)/(nu - 1)
}

