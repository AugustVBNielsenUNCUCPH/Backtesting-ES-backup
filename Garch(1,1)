  CC_H1 <- CC_test_GARCH(sim_H1_low$X, VaR_H1_0.025, ES_H1, alpha)
  ER_H1 <- ER_test_GARCH(sim_H1_low$X, ES_H1, VaR_H1_0.025, sigma_H0)
  VaR_hits <- VaR_stat_GARCH(sim_H1_low$X, VaR_H1)
  
  power_VaR_low[i] <- mean(VaR_hits > q_VaR)
  power_Z2_low[i] <- mean(Z2_H1 < q_Z2_low)
  power_Z3_low[i] <- mean(Z3_H1 < q_Z3_low)
  power_CC_low[i] <- CC_power(CC_H0_low, CC_H1)
  power_ER_low[i] <- ER_power(ER_H1, q_ER_low)}


