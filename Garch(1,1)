# GARCH(1,1) simulationsfunktion
simulate_garch <- function(T, omega, alpha, beta, nu, burn_in, M) {
  
  total <- T + burn_in
  tau <- sqrt((nu - 2) / nu)
  
  X <- matrix(0, M, total)
  sigma2 <- matrix(0, M, total)
  
  sigma2[,1] <- omega / (1 - alpha - beta)
  
  for (t in 2:total) {
    
    z <- rt(M, df = nu) * tau
    
    X[,t-1] <- sqrt(sigma2[,t-1]) * z
    
    sigma2[,t] <- omega +
                  alpha * X[,t-1]^2 +
                  beta  * sigma2[,t-1]
  }
  
  X <- X[, (burn_in+1):total]
  sigma <- sqrt(sigma2[, (burn_in+1):total])
  
  list(X = X, sigma = sigma)
}

# Find sigma under H0, givet X
simulate_sigma_from_X <- function(X, omega, alpha, beta) {
  
  M <- nrow(X)
  T <- ncol(X)
  
  sigma2 <- matrix(0, M, T)
  
  # Startværdi, ubetinget varians
  sigma2[,1] <- omega / (1 - alpha - beta)
  
  for(t in 2:T){
    sigma2[,t] <- omega +
                  alpha * X[,t-1]^2 +
                  beta  * sigma2[,t-1]
  }
  sqrt(sigma2)
}

# VaR OG ES
VaR_GARCH_stdt <- function(sigma, alpha, nu) {
  -sigma * qt(alpha, nu) * sqrt((nu - 2)/nu)
}

ES_GARCH_stdt <- function(sigma, alpha, nu) {
  q <- qt(alpha, nu)
  sigma * sqrt((nu - 2)/nu) *
    (dt(q, nu)/alpha) *
    (nu + q^2)/(nu - 1)
}

