# Halefordeling af negative afkast (tab vist som negative afkast)
alpha <- 0.025
nu <- 10

H_to_loss <- function(H, alpha, nu) {
  u <- alpha * (1 - H)
  -qt(u, df = nu) * sqrt((nu - 2)/nu)}

loss_density <- function(loss, nu) {
  z <- -loss * sqrt(nu/(nu - 2))
  dt(z, df = nu) * sqrt(nu/(nu - 2))}

# Risikomål
VaR <- -qt(alpha, nu) * sqrt((nu - 2)/nu)
q_a <- qt(alpha, nu)
ES <- sqrt((nu - 2)/nu) * (dt(q_a, nu)/alpha) * (nu + q_a^2)/(nu - 1)

loss_lower_D1 <- H_to_loss(0.2, alpha, nu)
loss_upper_D1 <- H_to_loss(0.8, alpha, nu)
loss_max_vis <- H_to_loss(0.99, alpha, nu)

loss_grid <- seq(VaR, loss_max_vis, length.out = 1000)
dens_H0 <- loss_density(loss_grid, nu)

dens_D1 <- ifelse(
  loss_grid >= loss_lower_D1 & loss_grid <= loss_upper_D1,
  loss_density(loss_grid, nu) / 0.6,
  0
)

# Konvetering til negative afkast
ret_grid <- -loss_grid
ret_VaR <- -VaR
ret_ES <- -ES
ret_lower_D1 <- -loss_upper_D1
ret_upper_D1 <- -loss_lower_D1
ret_min_vis <- -loss_max_vis

# Plot
col_H0 <- "darkcyan"
col_D1 <- "deeppink3"

plot(ret_grid, dens_H0,
     type = "n",
     xlim = c(ret_min_vis, ret_VaR),
     ylim = c(0, max(c(dens_H0, dens_D1)) * 1.05),
     xlab = expression("Realiseret afkast "*X[t]),
     ylab = "Tæthed",
     main = expression("Halefordeling af afkast givet VaR-overskridelse"),
     las = 1)

# Skygge under H0-kurven
polygon(c(ret_grid, rev(ret_grid)),
        c(dens_H0, rep(0, length(ret_grid))),
        col = adjustcolor(col_H0, alpha.f = 0.5),
        border = NA)

# Skygge under D1-kurven mellem grænserne 
mask <- ret_grid >= ret_lower_D1 & ret_grid <= ret_upper_D1
polygon(c(ret_grid[mask], rev(ret_grid[mask])),
        c(dens_D1[mask], rep(0, sum(mask))),
        col = adjustcolor(col_D1, alpha.f = 0.5),
        border = NA)

# Kurver
lines(ret_grid, dens_H0, col = col_H0, lwd = 2)
lines(ret_grid[mask], dens_D1[mask], col = col_D1, lwd = 2)

# Grænser 
abline(v = ret_lower_D1, col = col_D1, lty = 2, lwd = 2)
abline(v = ret_upper_D1, col = col_D1, lty = 2, lwd = 2)

legend("topleft",
       legend = c(expression(H[0]*": "*H[i] %~% U(0,1)),
                  expression(D[1]*": "*H[i] %~% U(0.2,0.8))),
       fill   = c(adjustcolor(col_H0, alpha.f = 0.35),
                  adjustcolor(col_D1, alpha.f = 0.45)),
       border = c(col_H0, col_D1),
       bty    = "n")

