# Ortogonale polynomier
## Shiftede Meixner-polynomier, ortogonale mht. Geom(a)
meixner_poly <- function(j, x, alpha) {
  x <- as.numeric(x)

  if (j == 0) return(rep(1, length(x)))

  Pm1 <- rep(1, length(x))
  Pm <- (1 - alpha * x) / sqrt(1 - alpha)

  if (j == 1) return(Pm)

  for (m in 1:(j - 1)) {
    num <- (1 - alpha) * (2*m + 1) + alpha * (m - x + 1)
    denom <- (m + 1) * sqrt(1 - alpha)
    coef <- num / denom
    coef[!is.finite(coef)] <- 0

    Pp1 <- coef * Pm - (m / (m + 1)) * Pm1

    Pm1 <- Pm
    Pm <- Pp1
  }
  Pm}

## Shiftede og normaliserede Legendre-polynomier, ortonormale mht. U(0,1)
legendre_poly <- function(j, y) {
  y <- pmin(pmax(y, 1e-8), 1 - 1e-8)
  x <- 2 * y - 1

  if (j == 0) return(rep(1, length(y)))

  Qm1 <- rep(1, length(y))
  Qm <- x

  if (j == 1) return(sqrt(3) * x)

  for (m in 1:(j - 1)) {
    Qp1 <- ((2*m + 1) / (m + 1)) * x * Qm - (m / (m + 1)) * Qm1
    Qm1 <- Qm
    Qm <- Qp1
  }
  sqrt(2*j + 1) * Qm}

# DS backtest på (d_i, H_i)
## test af K=4 univariate momenter i hver dimension og bivariate momenter afskåret ved K'=3.
ds_test_di_Hi <- function(d, H, alpha, K_uni = 4, K_biv = 3) {
  n <- length(d)
  if (n < 2) return(c(global = NA, freq = NA, sev = NA))

  Qs <- sapply(1:K_uni, function(j) mean(legendre_poly(j, H)))
  Ps <- sapply(1:K_uni, function(j) mean(meixner_poly(j, d, alpha)))

  cross <- c()
  d_i <- d[-n]; d_ip <- d[-1]
  H_i <- H[-n]; H_ip <- H[-1]
  for (k in 1:(K_biv - 1)) for (j in 1:(K_biv - k)) {
    cross <- c(cross,
      mean(meixner_poly(k, d_i, alpha) * meixner_poly(j, d_ip, alpha)),
      mean(legendre_poly(k, H_ip) * legendre_poly(j, H_i)),
      mean(meixner_poly(k, d, alpha) * legendre_poly(j, H)),
      mean(meixner_poly(k, d_ip, alpha) * legendre_poly(j, H_i))
    )}

  freq_V <- Ps
  sev_V <- Qs
  global_V <- c(Qs, Ps, cross)

  c(
    global = pchisq(n * sum(global_V^2), length(global_V), lower.tail = FALSE),
    freq = pchisq(n * sum(freq_V^2), length(freq_V), lower.tail = FALSE),
    sev = pchisq(n * sum(sev_V^2), length(sev_V), lower.tail = FALSE)
  )}

# DGP-simulationer (d_i, H_i), 3 datagenererende processer D1, D2 og D3 (H1) samt under H_0
sim_H0 <- function(T, alpha) {
  N_target <- ceiling(T * alpha) + 50 #Vi simulerer rigeligt med violations for at være sikker på dækning
  d <- rgeom(N_target, alpha) + 1
  cs <- cumsum(d)
  d <- d[cs <= T]
  H <- runif(length(d), 0, 1)
  list(d = d, H = H)}

sim_D1 <- function(T, alpha) {
  out <- sim_H0(T, alpha)
  out$H <- runif(length(out$d), 0.2, 0.8)
  out}

sim_D2 <- function(T, alpha) {
  N_target <- ceiling(T * alpha) + 50 #Vi simulerer rigeligt med violations for at være sikker på dækning
  d <- rnbinom(N_target, size = (1 - alpha) / alpha, prob = 0.5) + 1
  cs <- cumsum(d)
  d <- d[cs <= T]
  H <- runif(length(d), 0, 1)
  list(d = d, H = H)}

sim_D3 <- function(T, alpha) {
  out <- sim_D2(T, alpha)
  out$H <- runif(length(out$d), 0.2, 0.8)
  out}


# Kalibrering under H_0 og kritiske værdier 
alpha <- 0.025 #konsistent med projektet                      
T_sekvens <- c(250, 500, 750, 1000, 1250, 1500, 1750, 2000, 2250, 2500)
M0 <- 100000 #MC reps under H_0 (køres 8 gange i alt, én pr. T værdi)
M1 <- 10000 #MC reps under H_1 (køres 3 gange pr. T værdi, i alt 24)
K_uni <- 4
K_biv <- 3
signifikansniveau <- 0.0412 # konsistent med projekt

crit_vals <- list()
for (T_val in T_sekvens) {
  DS0 <- matrix(NA_real_, M0, 3,
                dimnames = list(NULL, c("global","freq","sev")))
  for (i in seq_len(M0)) {
    s <- sim_H0(T_val, alpha)
    DS0[i, ] <- ds_test_di_Hi(s$d, s$H, alpha, K_uni, K_biv)
  }
  crit_vals[[as.character(T_val)]] <- list(
    q_g = quantile(DS0[, "global"], signifikansniveau, na.rm = TRUE),
    q_f = quantile(DS0[, "freq"], signifikansniveau, na.rm = TRUE),
    q_s = quantile(DS0[, "sev"], signifikansniveau, na.rm = TRUE)
  )}

# Styrker
DGPs <- list(D1 = sim_D1, D2 = sim_D2, D3 = sim_D3)

styrke_resultater <- array(NA_real_,
  dim = c(length(DGPs), length(T_sekvens), 3),
  dimnames = list(DGP  = names(DGPs),
                  T = as.character(T_sekvens),
                  comp = c("global","freq","sev"))
)

for (dg in names(DGPs)) {
  for (T_val in T_sekvens) {
    cv <- crit_vals[[as.character(T_val)]]
    rej <- matrix(NA_real_, M1, 3,
                  dimnames = list(NULL, c("global","freq","sev")))
    for (i in seq_len(M1)) {
      s <- DGPs[[dg]](T_val, alpha)
      pv <- ds_test_di_Hi(s$d, s$H, alpha, K_uni, K_biv)
      rej[i, "global"] <- as.numeric(pv["global"] < cv$q_g)
      rej[i, "freq"] <- as.numeric(pv["freq"] < cv$q_f)
      rej[i, "sev"] <- as.numeric(pv["sev"] < cv$q_s)
    }
    styrke_resultater[dg, as.character(T_val), ] <- colMeans(rej, na.rm = TRUE)
  }}


# Plots
col_freq <- "deeppink3"
col_sev <- "cornflowerblue"
col_global <- "darkcyan"

dgp_cases <- list(
  D1 = expression("Severity-fejl: "*H[i] %~% U(0.2, 0.8)),
  D2 = expression("Frekvens-fejl: "*d[i]-1 %~% NB),
  D3 = expression("Begge fejl")
)

for (dg in names(DGPs)) {
  plot(T_sekvens,
       styrke_resultater[dg, , "global"],
       type = "n",
       lwd = 2,
       ylim = c(0, 1),
       xlim = c(min(T_sekvens), max(T_sekvens)),
       xlab = expression(T),
       ylab = "Styrke",
       xaxt = "n",
       yaxt = "n",
       main = dgp_cases[[dg]])
  abline(h = seq(0, 1, 0.1), col = "grey70")
  abline(v = T_sekvens,         col = "grey90")
  axis(2,
       at = seq(0, 1, 0.1),
       labels = sprintf("%.1f", seq(0, 1, 0.1)),
       las = 1)
  axis(1,
       at = T_sekvens,
       labels = T_sekvens,
       las = 2,
       cex.axis = 0.7)
  lines(T_sekvens, styrke_resultater[dg, , "global"],
        col = col_global, lwd = 3)
  lines(T_sekvens, styrke_resultater[dg, , "freq"],
        col = col_freq, lwd = 3)
  lines(T_sekvens, styrke_resultater[dg, , "sev"],
        col = col_sev, lwd = 3)
  abline(h = signifikansniveau, col = "grey40", lwd = 2, lty = 2)
  legend("right",
         legend = c("Global", "Frekvens", "Severity"),
         col = c(col_global, col_freq, col_sev),
         lwd = 3,
         bty = "n")
}

