# Fordelinger af d_i og H_i under H0 og H1 (D1, D2) ved T = 250
set.seed(2026)
T_demo <- 250
n_demo <- 5000

saml_d <- function(sim_fn, T, alpha, n) {
  out_list <- vector("list", n)
  for (i in 1:n) out_list[[i]] <- sim_fn(T, alpha)$d
  unlist(out_list, use.names = FALSE)
}
saml_H <- function(sim_fn, T, alpha, n) {
  out_list <- vector("list", n)
  for (i in 1:n) out_list[[i]] <- sim_fn(T, alpha)$H
  unlist(out_list, use.names = FALSE)
}

d_H0 <- saml_d(sim_H0, T_demo, alpha, n_demo)
d_D2 <- saml_d(sim_D2, T_demo, alpha, n_demo)
H_H0 <- saml_H(sim_H0, T_demo, alpha, n_demo)
H_D1 <- saml_H(sim_D1, T_demo, alpha, n_demo)


# Plot
col_H0 <- "darkcyan"
col_H1 <- "deeppink3"

# d_i fordeling
d_combined <- c(d_H0, d_D2)
d_upper <- ceiling(quantile(d_combined, 0.99))
d_max_all <- max(d_combined)
bins_d <- seq(1, d_max_all + 2, by = 2)

h_H0 <- hist(d_H0, breaks = bins_d, plot = FALSE)
h_D2 <- hist(d_D2, breaks = bins_d, plot = FALSE)

y_max_d <- max(h_H0$density, h_D2$density) * 1.05

plot(h_H0, freq = FALSE,
     col = adjustcolor(col_H0, alpha.f = 0.5),
     border = col_H0,
     xlim = c(0, d_upper),
     ylim = c(0, y_max_d),
     xlab = expression(d[i]),
     ylab = "Tæthed",
     main = expression("Fordeling af "*d[i]*" ved T = 250 | " * alpha * " = 0.025"),
     las = 1)
plot(h_D2, freq = FALSE,
     col = adjustcolor(col_H1, alpha.f = 0.5),
     border = col_H1,
     add = TRUE)
legend("topright",
       legend = c(expression(H[0]*": Geom(" * alpha * ")"),
                  expression(D[2]*": NB((1-" * alpha * ")/" * alpha * ", 0.5)")),
       fill = c(adjustcolor(col_H0, alpha.f = 0.5),
                adjustcolor(col_H1, alpha.f = 0.5)),
       border = c(col_H0, col_H1),
       bty = "n")


