# Heatmap
par(mfrow = c(1, 3), mar = c(4.5, 4.5, 2.5, 1), oma = c(0, 0, 2, 0))

plot_heatmap <- function(mat, main_txt) {
  nr <- nrow(mat); nc <- ncol(mat)
  cols <- colorRampPalette(c("white", "aquamarine1", "aquamarine4"))(100)
  image(1:nc, 1:nr, t(mat[nr:1, , drop = FALSE]),
        col = cols, zlim = c(0, 1),
        axes = FALSE, xlab = "T", ylab = "DGP",
        main = main_txt)
  axis(1, at = 1:nc, labels = colnames(mat), las = 2, cex.axis = 0.85)
  axis(2, at = 1:nr, labels = rev(rownames(mat)), las = 1)
  box()
  for (i in 1:nr) for (j in 1:nc) {
    val  <- mat[i, j]
    txt_col <- if (val > 0.55) "white" else "black"
    text(j, nr - i + 1, sprintf("%.2f", val),
         col = txt_col, cex = 0.85)
  }}

