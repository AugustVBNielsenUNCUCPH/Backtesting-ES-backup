```{r DS_helpers}
# (d_i, H_i) udledes fra afkastserie under H_0-prædiktion (t_10)
afkast_til_dH <- function(X_row, VaR_val, nu_pred) {
  I <- X_row + VaR_val < 0
  if (sum(I) < 2) return(list(d = integer(0), H = numeric(0)))
  times <- which(I)
  d <- diff(c(0, times))
  u <- pt(X_row[I], df = nu_pred)
  H <- pmin(pmax((alpha - u) / alpha, 1e-8), 1 - 1e-8)
  list(d = d, H = H)}

DS_pvalues_matrix <- function(X, VaR_val, nu_pred, alpha, K_uni, K_biv) {
  M <- nrow(X)
  DS <- matrix(NA_real_, M, 3,
               dimnames = list(NULL, c("global", "freq", "sev")))
  for (i in 1:M) {
    dH <- afkast_til_dH(X[i, ], VaR_val, nu_pred)
    if (length(dH$d) >= 2) {
      DS[i, ] <- ds_test_di_Hi(dH$d, dH$H, alpha, K_uni, K_biv)
    }
  }
  DS}
