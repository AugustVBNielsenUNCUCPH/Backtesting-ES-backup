# H_0: X_t ~ t_10 (uskaleret), ER- og CC-kalibrering plus DS-kritiske værdier
# Genbruger den eksisterende X_t_10-matrix hvis tilgængelig
X_H0 <- matrix(rt(T * M0, df = nu_H0), nrow = M0, ncol = T)

# Ubetinget volatilitet for t_10 (uskaleret): sqrt(nu/(nu-2))
sigma_H0 <- sqrt(nu_H0 / (nu_H0 - 2))

ER_H0 <- ER_iid(X_H0, VaR_nu_10, ES_nu_10, sigma_H0)
CC_H0 <- CC_iid(X_H0, VaR_nu_10, ES_nu_10, alpha)
DS_H0 <- DS_pvalues_matrix(X_H0, VaR_nu_10, nu_H0, alpha, K_uni, K_biv)

q_ER <- quantile(ER_H0, signifikansniveau, na.rm = TRUE)
q_DS_freq <- quantile(DS_H0[, "freq"], signifikansniveau, na.rm = TRUE)
q_DS_sev <- quantile(DS_H0[, "sev"], signifikansniveau, na.rm = TRUE)
q_DS_global <- quantile(DS_H0[, "global"], signifikansniveau, na.rm = TRUE)
