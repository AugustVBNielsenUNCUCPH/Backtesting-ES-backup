```{r}
# ER og CC under i.i.d. (konstant VaR og ES) - tilpasset fra GARCH-versionerne i kapitel 5

# ER, McNeil-Frey, med konstant sigma under i.i.d. (ubetinget volatilitet)
ER_iid <- function(X, VaR_val, ES_val, sigma_val) {
  I <- (X + VaR_val) < 0
  r <- ((X + ES_val) * I) / sigma_val
  rbar <- rowSums(r) / rowSums(I)
  rbar[!is.finite(rbar)] <- NA
  rbar}

# CC, Nolde-Ziegel, konstant risikomål
CC_iid <- function(X, VaR_val, ES_val, alpha) {
  M <- nrow(X); T <- ncol(X)
  T_CC <- matrix(0, M, 2)
  for (i in 1:M) {
    xt <- X[i, ]
    I  <- (xt + VaR_val < 0) * 1
    V  <- cbind(
      alpha - I,
      VaR_val - ES_val - (1/alpha) * I * (VaR_val + xt)
    )
    Omega <- crossprod(V) / T
    T_CC[i, ] <- sqrt(T) * diag(Omega)^(-1/2) * colMeans(V)
  }
  T_CC}

CC_power <- function(T_CC_null, T_CC) {
  pi1 <- ecdf(T_CC_null[, 1])
  pi2 <- ecdf(T_CC_null[, 2])
  eta <- 2 * pmin(pi1(T_CC[, 1]), pi2(T_CC[, 2]))
  eta <- pmin(eta, 1)
  mean(eta < signifikansniveau)
}
