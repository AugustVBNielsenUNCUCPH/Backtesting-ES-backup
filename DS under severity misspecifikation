```{r styrke_matrix}
# Power matrix: 7 tests × 7 nu-værdier
power_matrix_7_3 <- matrix(NA, nrow = length(H1_seq), ncol = 8)
colnames(power_matrix_7_3) <- c("VaR", "Z2", "Z3", "ER", "CC", "T_F", "T_S", "T_G")
rownames(power_matrix_7_3) <- paste0("df = ", H1_seq)

for (i in seq_along(H1_seq)) {

  n <- H1_seq[i]

  Forskydning_t_seq_10 <- VaR(qt, p = alpha, df = n) - VaR_nu_10

  X_t_H1_seq_10_fixedVaR <- matrix(rt(T * M1, df = n), nrow = M1, ncol = T) +
                            Forskydning_t_seq_10

  # VaR_1%
  N_fixedVaR <- VaR_exceptions(X_t_H1_seq_10_fixedVaR, VaR_nu_10_alph_0.01)
  power_matrix_7_3[i, "VaR"] <- VaR_styrke(N_fixedVaR, q5)

  # Z2
  Z2_fixedVaR <- Z2(X_t_H1_seq_10_fixedVaR, VaR_nu_10, ES_nu_10, alpha)
  power_matrix_7_3[i, "Z2"] <- Z_styrke(Z2_fixedVaR, qt_t_fixedVaR_10_Z2[1])

  # Z3
  Z3_fixedVaR <- Z3(X_t_H1_seq_10_fixedVaR, df_H0 = nu_H0, alpha,
                    tau = 1, mu = 0)
  power_matrix_7_3[i, "Z3"] <- Z_styrke(Z3_fixedVaR, qt_t_fixedVaR_10_Z3[1])

  # ER
  ER_fixedVaR <- ER_iid(X_t_H1_seq_10_fixedVaR, VaR_nu_10, ES_nu_10, sigma_H0)
  power_matrix_7_3[i, "ER"] <- Z_styrke(ER_fixedVaR, q_ER)

  # CC
  CC_fixedVaR <- CC_iid(X_t_H1_seq_10_fixedVaR, VaR_nu_10, ES_nu_10, alpha)
  power_matrix_7_3[i, "CC"] <- CC_power(CC_H0, CC_fixedVaR)

  # DS
  DS_fixedVaR <- DS_pvalues_matrix(X_t_H1_seq_10_fixedVaR, VaR_nu_10,
                                    nu_H0, alpha, K_uni, K_biv)
  power_matrix_7_3[i, "T_F"] <- mean(DS_fixedVaR[, "freq"] < q_DS_freq, na.rm = TRUE)
  power_matrix_7_3[i, "T_S"] <- mean(DS_fixedVaR[, "sev"]  < q_DS_sev,  na.rm = TRUE)
  power_matrix_7_3[i, "T_G"] <- mean(DS_fixedVaR[, "global"] < q_DS_global, na.rm = TRUE)}
