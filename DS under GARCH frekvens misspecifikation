```{r}
set.seed(2026)
alpha <- 0.025

ds_di_Hi <- function(X, sigma, VaR, alpha, nu) {
  M <- nrow(X)
  tau <- sqrt((nu - 2)/nu)

  lapply(1:M, function(m) {
    idx <- which(X[m, ] < -VaR[m, ])
    if (length(idx) < 2) return(list(d = integer(0), H = numeric(0)))

    d <- diff(c(0, idx))
    z <- X[m, idx] / sigma[m, idx] / tau
    u <- pmin(pmax(pt(z, df = nu), 1e-10), 1 - 1e-10)
    H <- pmin(pmax((alpha - u) / alpha, 1e-10), 1 - 1e-10)

    list(d = d, H = H)})}

# ds_test_di_Hi anvendes fra tidligere kode i vores environment 
ds_pv <- function(dH, alpha) {
  t(sapply(dH, function(x) {
    if (length(x$d) < 2) c(global = NA, freq = NA, sev = NA)
    else ds_test_di_Hi(x$d, x$H, alpha)}))}
```

